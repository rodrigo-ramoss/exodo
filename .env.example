# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Chave da API do Gemini (Google AI Studio)
GEMINI_API_KEY="sua_chave_gemini_aqui"

# ─── URL do App ───────────────────────────────────────────────────────────────
# URL base do app — usada nos links de retorno do Stripe
# Em produção: https://exodo-app.vercel.app (ou seu domínio customizado)
APP_URL="https://exodo-app.vercel.app"
NEXT_PUBLIC_SITE_URL="https://exodo-app.vercel.app"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Chave secreta do Stripe (Dashboard → Developers → API Keys)
STRIPE_SECRET_KEY="sk_live_..."

# Price ID do plano mensal (Dashboard → Products → copie o Price ID)
# O Price ID atual do Voz do Deserto: price_1THuvNPDxOsGzCZMoDUxsNLA
STRIPE_MONTHLY_PRICE_ID="price_..."

# Webhook secret — crie um novo webhook no Stripe apontando para:
# https://exodo-app.vercel.app/api/webhook
# (Dashboard → Developers → Webhooks → Add endpoint)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Brevo (e-mail marketing, opcional) ──────────────────────────────────────
# Chave da API do Brevo para adicionar assinantes à lista de e-mail
BREVO_API_KEY="sua_chave_brevo_aqui"
